{
  "workdir": "/workdir",
  "base_image": "rust:slim-bookworm",
  "setup_commands": [
    "apt-get update",
    "apt-get install -y pkg-config libssl-dev build-essential",
    "rm -rf /var/lib/apt/lists/*",
    "rustup component add rustfmt",
    "rustup component add clippy"
  ],
  "env": ["SQLX_OFFLINE=true"]
}
